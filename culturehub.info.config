# Server block for culturehub.info
# version: 1.0
server {
    listen 80;
    listen [::]:80;
    server_name culturehub.info www.culturehub.info;

    root /var/www/culturehub.info;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }

    access_log /var/log/nginx/culturehub.access.log;
    error_log /var/log/nginx/culturehub.error.log;
}
